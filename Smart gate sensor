#include <Servo.h>

const int trigPin = 3;
const int echoPin = 5;
const int buzzer = 7;

Servo myServo;

long duration;
int distance;

void setup() {
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(buzzer, OUTPUT);

  myServo.attach(6);
}

void loop() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH);
  distance = duration * 0.034 / 2;

  if (distance > 0 && distance < 20) {
    myServo.write(90);
    tone(buzzer, 1000);
  } else {
    myServo.write(0);
    noTone(buzzer);
  }

  delay(200);
}
